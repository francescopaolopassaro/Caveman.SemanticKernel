<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Caveman.SemanticKernel</PackageId>
    <Version>1.3.0</Version>
    <Authors>Francesco Paolo Passaro</Authors>
    <Company>Francesco Paolo Passaro</Company>
    <Description>Semantic Kernel plugins for Caveman (NLP Prompt Compressor): prompt token optimization, conversation/agent context tools (summarize, fit-to-budget, memory, focus, token estimate), developer services and on-demand project documentation. Add-on package; references the dependency-free Caveman core. Licensed under the Caveman License (MIT + mandatory attribution to Passaro Francesco Paolo - Digitalsolutions.it).</Description>
    <PackageTags>AI;NLP;LLM;PromptEngineering;SemanticKernel;Agents</PackageTags>
    <RepositoryUrl>https://github.com/francescopaolopassaro/caveman-semantickernel</RepositoryUrl>
    <PackageReleaseNotes>1.3.0: two new plugins for Caveman 1.3.0 content-aware pipeline. CavemanRouterPlugin: route_content (auto-detects type and applies best compressor), detect_content_type, compress_json (SmartCrusher with CCR), retrieve_ccr, analyze_waste, batch_route. CavemanOutputPlugin: shape_system_prompt (verbosity steering L0-L4), remove_verbosity_steering, has_verbosity_steering, scan_volatile_tokens (UUID/JWT/timestamp/hash detection for KV-cache protection), has_volatile_tokens, optimize_for_cache. All existing plugins unchanged; additive release.</PackageReleaseNotes>

    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Title>Caveman.SemanticKernel</Title>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Copyright>Copyright (c) 2026 Passaro Francesco Paolo - Digitalsolutions.it</Copyright>
    <PackageProjectUrl>https://github.com/francescopaolopassaro/caveman-semantickernel/</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <PackageRequireLicenseAcceptance>False</PackageRequireLicenseAcceptance>
    <RootNamespace>caveman.core.SemanticKernel.Plugin</RootNamespace>
    <AssemblyName>Caveman.SemanticKernel</AssemblyName>
    <PackageIcon>caveman-icon.png</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tests\**" />
  </ItemGroup>

<ItemGroup>
  <None Include="caveman-icon.png" Pack="true" PackagePath="\" />
</ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SemanticKernel" Version="1.74.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Local development reference to the Caveman core. When packing, NuGet emits this as a
         dependency on the published "Caveman" package (same version). Switch to a PackageReference
         once Caveman 1.2.1 is published if you build this repo in isolation. -->
    <ProjectReference Include="..\caveman\caveman.core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="CHANGELOG.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="LICENSE">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
